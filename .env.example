# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.

# Yönetim paneli giriş şifresi
ADMIN_PASSWORD=guclu-bir-sifre-girin

# Oturum çerezi imza anahtarı (openssl rand -hex 32 ile üretebilirsiniz)
SESSION_SECRET=uzun-rastgele-gizli-anahtar

# (Opsiyonel) Veritabanı dosyasının yolu — varsayılan: ./data/app.db
# DATABASE_PATH=/mutlak/yol/app.db
